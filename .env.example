# ─── CrestFlow Platform Environment Variables ──────────────────────────────
# Copy this file to .env.local and fill in actual values.
# NEVER commit .env.local to version control.

# ─── Network Switch (ONE CHANGE TO RULE THEM ALL) ──────────────────────────
# Set to 'testnet' for development, 'mainnet' for production.
# This single flag cascades to: USDC ASA ID, Folks Finance app IDs,
# Tinyman API URL, Pact pools, GoPlausible DID prefix, x402 network label.
ALGORAND_NETWORK=testnet

# Algorand nodes — must match ALGORAND_NETWORK
# Testnet: testnet-api.4160.nodely.dev / testnet-idx.4160.nodely.dev
# Mainnet: mainnet-api.4160.nodely.dev / mainnet-idx.4160.nodely.dev
ALGORAND_ALGOD_URL=https://testnet-api.4160.nodely.dev
ALGORAND_ALGOD_TOKEN=
ALGORAND_INDEXER_URL=https://testnet-idx.4160.nodely.dev
ALGORAND_INDEXER_TOKEN=

# ─── Server ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=info

# ─── Database (PostgreSQL) ──────────────────────────────────────────────────
DATABASE_URL=postgresql://crestflow:crestflow_dev@localhost:5432/crestflow?connection_limit=25

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT / Auth ─────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-secure-random-string-minimum-64-characters-long
JWT_EXPIRES_IN=7d

# ─── Google OAuth ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Turnkey (Embedded Wallet) ──────────────────────────────────────────────
TURNKEY_API_BASE_URL=https://api.turnkey.com
TURNKEY_ORGANIZATION_ID=your-turnkey-org-id
TURNKEY_API_PUBLIC_KEY=your-turnkey-api-public-key
TURNKEY_API_PRIVATE_KEY=your-turnkey-api-private-key

# ─── CoinGecko ──────────────────────────────────────────────────────────────
COINGECKO_API_URL=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=

# ─── Gora Oracle (disabled — using CoinGecko) ──────────────────────────────
GORA_ORACLE_APP_ID=
GORA_ORACLE_ENABLED=false

# ─── KYC Bypass (development only) ─────────────────────────────────────────
# Set to 'true' to skip KYC gate in policy engine during development
KYC_BYPASS=true

# ─── Veriff KYC ────────────────────────────────────────────────────────────
VERIFF_API_KEY=
VERIFF_API_SECRET=
VERIFF_API_URL=https://stationapi.veriff.com/v1
VERIFF_WEBHOOK_SECRET=

# ─── GoPlausible (DID/VC + x402 Facilitator) ───────────────────────────────
# Facilitator API is PUBLIC — no API key needed for payment verification
GOPLAUSIBLE_API_URL=https://facilitator.goplausible.xyz
GOPLAUSIBLE_API_KEY=
GOPLAUSIBLE_FACILITATOR_ADDRESS=your-algorand-address-for-receiving-payments

# ─── Transak (On-Ramp / Off-Ramp) ──────────────────────────────────────────
TRANSAK_API_KEY=
TRANSAK_API_SECRET=
TRANSAK_WEBHOOK_SECRET=

# ─── OpenAI (Copilot Primary LLM) ──────────────────────────────────────────
OPENAI_API_KEY=

# ─── Google AI / Gemini (Copilot Fallback LLM) ─────────────────────────────
GOOGLE_AI_API_KEY=

# ─── x402 Micropayment Config ──────────────────────────────────────────────
# USDC ASA ID is auto-resolved from ALGORAND_NETWORK (no need to set)
# testnet: 10458941 | mainnet: 31566704
X402_USDC_ASA_ID=10458941
X402_ENABLED=false
