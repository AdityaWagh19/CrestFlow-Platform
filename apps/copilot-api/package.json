{
  "name": "copilot-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --build && tsc-alias",
    "start": "node dist/server.js",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@crestflow/shared": "workspace:*",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@prisma/client": "^6.2.0",
    "algosdk": "^3.2.0",
    "bullmq": "^5.34.0",
    "decimal.js": "^10.4.3",
    "fastify": "^5.2.0",
    "ioredis": "^5.4.0",
    "jose": "^6.0.0",
    "pino": "^9.6.0",
    "rate-limiter-flexible": "^5.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.2.0",
    "tsc-alias": "^1.8.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
